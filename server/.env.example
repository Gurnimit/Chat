# ── Server Environment Variables Blueprint ──────────────────────────────────────
PORT=5000
NODE_ENV=development # development | production | test
DATABASE_URL="postgresql://user:password@localhost:5432/velvet_chat?schema=public"

# Security Secrets
ACCESS_TOKEN_SECRET="your-super-secret-access-key-min-32-chars"
REFRESH_TOKEN_SECRET="your-super-secret-refresh-key-min-32-chars"

# CORS Allowed Origins (Comma-separated)
ALLOWED_ORIGINS="http://localhost:5173,http://localhost:5000,https://api.velvetchat.app"

# Application Settings
EMAIL_VERIFICATION_REQUIRED=false

# Firebase Push Notifications (Optional in dev)
FIREBASE_SERVICE_ACCOUNT_PATH=""
FCM_ENABLED=false

# S3 Cloud Storage (Optional - falls back to local disk if omitted)
S3_ENDPOINT=""
S3_BUCKET=""
S3_ACCESS_KEY=""
S3_SECRET_KEY=""

# TURN / STUN WebRTC Relay Credentials
TURN_URLS="turn:openrelay.metered.ca:80,turn:openrelay.metered.ca:443"
TURN_USERNAME="openrelayproject"
TURN_PASSWORD="openrelayproject"
