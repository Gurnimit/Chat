# Root Environment Variables Blueprint for Velvet Chat
POSTGRES_USER=velvet_admin
POSTGRES_PASSWORD=secure_prod_password_123
POSTGRES_DB=velvet_chat

# Backend Server Secrets
PORT=5000
NODE_ENV=production
DATABASE_URL="postgresql://velvet_admin:secure_prod_password_123@postgres:5432/velvet_chat?schema=public"
ACCESS_TOKEN_SECRET="prod_access_secret_key_change_me_in_vault_32chars"
REFRESH_TOKEN_SECRET="prod_refresh_secret_key_change_me_in_vault_32chars"
ALLOWED_ORIGINS="https://velvetchat.app,https://api.velvetchat.app"

# Client Configuration
VITE_API_URL=https://api.velvetchat.app
